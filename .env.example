# 复制为 .env 或在 Render 控制台里配置这些环境变量

# JWT 签名密钥（生产环境务必设置一个长随机串；不设则每次重启失效）
# 生成方法： python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=

# Claude API Key（真·AI 对话需要；不填则自动回退到内置智能逻辑）
ANTHROPIC_API_KEY=

# 使用的模型：默认 claude-opus-4-8（最强）。
# 想更省钱可改 claude-haiku-4-5（最便宜）或 claude-sonnet-4-6（均衡）。
ANTHROPIC_MODEL=claude-opus-4-8

# Postgres 连接串（数据持久化）。不填则使用本地 SQLite 文件 data/app.db（仅适合本机/测试）。
# Render Blueprint 会自动注入；用 Neon/Supabase 时填它给的 connection string。
DATABASE_URL=

# 端口（Render 会自动注入 PORT；本地默认 8000）
# PORT=8000
